# String Interpolation in Nova

let name = "World"
print("Hello, {name}!")

let age = 25
print("I am {age} years old.")

# Expressions in interpolation
let a = 10
let b = 20
print("{a} + {b} = {a + b}")

# Nested function calls
let items = ["apple", "banana", "cherry"]
print("I have {len(items)} items.")

# Multiple interpolations
let first = "Nova"
let version = 1
print("{first} v{version} is awesome!")
